# Required: Public.com brokerage API token
PUBLIC_ACCESS_TOKEN=your_bearer_token_here

# Required: WorldMonitor base URL (self-hosted or managed instance)
WM_BASE_URL=http://your-worldmonitor-host:8000

# Optional: WorldMonitor API key (if your instance requires auth)
WORLDMONITOR_API_KEY=

# Optional: Finnhub API key (for market data)
FINNHUB_API_KEY=

# Optional: EIA API key (for energy data)
EIA_API_KEY=

# Safety gate: must be explicitly set to 'true' to enable live order submission
EXECUTION_ENABLED=false
